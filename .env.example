# ============================================================
# Qing Li Mall - 环境变量配置示例
# 复制此文件为 .env 并修改对应值后运行 deploy.sh
# ============================================================

# MySQL root 密码
MYSQL_ROOT_PASSWORD=668668

# MinIO 账号密码（请修改为强密码！）
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=Admin123456!

# 前端允许跨域的地址（填写服务器 IP 或域名）
# 示例: http://43.159.171.238 或 https://yourdomain.com
FRONTEND_URL=http://YOUR_SERVER_IP

# JWT 密钥（请修改为随机字符串，长度 >= 32）
JWT_SECRET=qingli-jwt-secret-key-2026-must-be-at-least-256-bits-long

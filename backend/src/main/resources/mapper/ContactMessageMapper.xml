<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qingli.mall.mapper.ContactMessageMapper">

    <resultMap id="MsgRM" type="com.qingli.mall.entity.ContactMessage">
        <id     column="id"         property="id"/>
        <result column="form_type"  property="formType"/>
        <result column="name"       property="name"/>
        <result column="email"      property="email"/>
        <result column="phone"      property="phone"/>
        <result column="company"    property="company"/>
        <result column="subject"    property="subject"/>
        <result column="product"    property="product"/>
        <result column="quantity"   property="quantity"/>
        <result column="message"    property="message"/>
        <result column="status"     property="status"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO contact_message (form_type, name, email, phone, company, subject,
                                     product, quantity, message, ip_address)
        VALUES (#{formType}, #{name}, #{email}, #{phone}, #{company}, #{subject},
                #{product}, #{quantity}, #{message}, #{ipAddress})
    </insert>

    <select id="findAll" resultMap="MsgRM">
        SELECT * FROM contact_message ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="MsgRM">
        SELECT * FROM contact_message WHERE id = #{id}
    </select>

    <select id="findRecent" resultMap="MsgRM">
        SELECT * FROM contact_message ORDER BY created_at DESC LIMIT #{limit}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM contact_message
    </select>

    <select id="countByStatus" resultType="long">
        SELECT COUNT(*) FROM contact_message WHERE status = #{status}
    </select>

    <select id="findAllPaged" resultMap="MsgRM">
        SELECT * FROM contact_message
        <where>
            <if test="status != null">AND status = #{status}</if>
            <if test="formType != null and formType != ''">AND form_type = #{formType}</if>
            <if test="date != null and date != ''">AND DATE(created_at) = #{date}</if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countAllFiltered" resultType="long">
        SELECT COUNT(*) FROM contact_message
        <where>
            <if test="status != null">AND status = #{status}</if>
            <if test="formType != null and formType != ''">AND form_type = #{formType}</if>
            <if test="date != null and date != ''">AND DATE(created_at) = #{date}</if>
        </where>
    </select>

    <update id="updateStatus">
        UPDATE contact_message SET status = #{status} WHERE id = #{id}
    </update>

    <delete id="deleteById">DELETE FROM contact_message WHERE id = #{id}</delete>

</mapper>

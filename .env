# ─────────────────────────────────────────────────────────────
# Qing Li Mall 环境变量配置
# 修改此文件后重新运行 deploy.sh 即可生效
# ─────────────────────────────────────────────────────────────

# MySQL root 密码（Docker 自动创建）
MYSQL_ROOT_PASSWORD=668668

# MinIO 账号密码（复用服务器上已有的 MinIO 容器，9000 端口）
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=Admin123456!

# 前端访问地址（用于 CORS 白名单）
FRONTEND_URL=http://43.159.171.238

# JWT 签名密钥（生产环境请改成随机字符串）
JWT_SECRET=qingli-jwt-secret-key-2026-must-be-at-least-256-bits-long
